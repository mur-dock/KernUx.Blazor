@inherits LayoutComponentBase

<KernKopfzeile />

<header class="demo-header">
    <KernContainer>
        <KernRow JustifyContent="JustifyContent.Between" AlignItems="AlignItems.Center">
            <KernCol Span="9">
                <KernPreline>KERN Design System</KernPreline>
                <KernTitle Size="TitleSize.Large">KernUx.Blazor Showcase</KernTitle>
            </KernCol>
            <KernCol Span="3" class="demo-header__actions">
                @* SSR-sicher: reiner HTML-Button mit JS-Handler statt Blazor @onclick. *@
                <button type="button"
                        class="kern-btn kern-btn--tertiary"
                        title="Theme wechseln"
                        aria-label="Theme wechseln"
                        onclick="window.kernTheme.toggle()">
                    <span class="kern-icon kern-icon--brightness-medium" aria-hidden="true"></span>
                </button>
            </KernCol>
        </KernRow>
    </KernContainer>
</header>

<KernContainer>
    <KernRow>
        <KernCol Span="12" SpanMd="3">
            <DemoNavMenu />
        </KernCol>
        <KernCol Span="12" SpanMd="9">
            <main>
                @Body
            </main>
        </KernCol>
    </KernRow>
</KernContainer>

<div id="blazor-error-ui" data-nosnippet>
    Ein unbehandelter Fehler ist aufgetreten.
    <a href="." class="reload">Neu laden</a>
    <span class="dismiss">🗙</span>
</div>
